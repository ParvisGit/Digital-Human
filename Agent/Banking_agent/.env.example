# =============================================================================
# Banking Agent - Environment Configuration Template
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Data Source Configuration
# -----------------------------------------------------------------------------
# Set to 'true' to load prompts and interim messages from database (MongoDB/Redis)
# Set to 'false' or leave unset to load from codebase files
LOAD_FROM_DB=false

# -----------------------------------------------------------------------------
# Twilio OTP Credentials (for fraud actions: block card, freeze account)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# SMTP Email OTP Credentials (for general authentication)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=True
OTP_PEPPER=your_random_hex_string_for_otp_hashing

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# OpenAI (set this to use model_provider: "openai" in config.json)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (set this to use model_provider: "anthropic" in config.json)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google Vertex AI (defaults used if not set)
GOOGLE_PROJECT=your-gcp-project-id
GOOGLE_LOCATION=us-central1

# -----------------------------------------------------------------------------
# Optional: Redis Configuration
# -----------------------------------------------------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Optional: MongoDB Configuration
# -----------------------------------------------------------------------------
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=your_database_name
