# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=bfsi_chat_logs_queue

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongo_uri = os.getenv(
        "MONGO_URI",
        "mongodb://giniiris-voice:DnRGRJzCqSSw72akH58N_FBvNFCHeHOEWz7JzgKQNQinuWo0@9fea8197-616e-4aa8-ad5f-56452a96f42d.asia-south2.firestore.goog:443/giniiris-voice-cdr-db?loadBalanced=true&tls=true&authMechanism=SCRAM-SHA-256&retryWrites=false"
    )
MONGO_DB=bfsi_logs
MONGO_COLLECTION=chat_logs

# ── WebSocket Forwarding ──────────────────────────────────
# Enable/disable WebSocket forwarding (set to "false" to skip)
WS_ENABLED=true

# WebSocket server URL (use wss:// in production with TLS)
WS_URL=ws://localhost:8765

# Bearer token for authentication (match server WS_AUTH_TOKEN)
WS_AUTH_TOKEN=change-me-in-production

# Connection tuning
WS_CONNECT_TIMEOUT=5
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10
WS_BUFFER_SIZE=500

# ── Retry / resilience ────────────────────────────────────
MAX_REDELIVER_COUNT=3
LOG_LEVEL=INFO
